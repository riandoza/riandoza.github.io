---
import { projects } from '../data/portfolio';
---

<section id="projects">
  <div class="container">
    <p class="eyebrow reveal">03 — Projects</p>
    <h2 class="section-title reveal">
      Featured <span class="accent">work</span>
    </h2>
    <p class="section-subtitle reveal">
      A few things I've built and maintained. There's more on my GitHub — these
      are the ones I keep coming back to.
    </p>

    <div class="grid">
      {
        projects.map((p) => (
          <a
            class="card reveal"
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="card-top">
              <svg class="folder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </svg>
              <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17 17 7M7 7h10v10" />
              </svg>
            </div>
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <ul class="tags">
              {p.tags.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-5px);
    box-shadow: 0 18px 44px -22px var(--accent-glow);
  }
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }
  .folder {
    width: 38px;
    height: 38px;
    color: var(--accent);
  }
  .arrow {
    width: 20px;
    height: 20px;
    color: var(--text-dim);
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .card:hover .arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
  .card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .tags li {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent-2);
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border-soft);
    border-radius: 6px;
  }
</style>
