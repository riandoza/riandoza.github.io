---
import { profile } from '../data/portfolio';
---

<section id="about">
  <div class="container">
    <p class="eyebrow reveal">01 — About</p>
    <h2 class="section-title reveal">
      A bit <span class="accent">about me</span>
    </h2>

    <div class="about-grid">
      <div class="about-card reveal">
        <p class="about-text">{profile.summary}</p>
        <p class="about-text">
          What I enjoy most is owning a problem end to end — whether that's
          crafting a clean, responsive frontend, designing a resilient API, or
          setting up monitoring across a fleet of Linux servers. I care about the
          details, communicate clearly, and ship work I'm proud to put my name on.
        </p>
        <div class="meta">
          <span class="dot"></span>
          Based in {profile.location} · Open to freelance & collaboration
        </div>
      </div>

      <ul class="highlights">
        {
          profile.highlights.map((h) => (
            <li class="reveal">
              <span class="hl-icon">{h.icon}</span>
              <div>
                <span class="hl-label">{h.label}</span>
                <span class="hl-text">{h.text}</span>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .about-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .about-text {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .about-text:last-of-type {
    margin-bottom: 1.5rem;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text);
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 99px;
    background: #34d399;
    box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.18);
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .highlights li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    padding: 1rem 1.15rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .highlights li:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }
  .hl-icon {
    font-size: 1.3rem;
    line-height: 1.4;
  }
  .hl-label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 0.15rem;
  }
  .hl-text {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
