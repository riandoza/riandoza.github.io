---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { LEGAL_LAST_UPDATED, formatSiteDate } from '../data/site';

const title = 'Terms of Use — Riandoza';
const description =
  'Terms of Use for Riandoza, covering acceptable use, content ownership, external links, disclaimers, and limitations.';
const updatedAt = formatSiteDate(LEGAL_LAST_UPDATED);
---

<Layout title={title} description={description}>
  <Nav />
  <main class="legal-page">
    <article class="container legal-content">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Use</h1>
      <p class="legal-updated">Last updated: {updatedAt}</p>

      <p>
        These Terms of Use govern your access to and use of this website. By
        using the site, you agree to these terms.
      </p>

      <h2>Use of the Website</h2>
      <p>
        You may browse this website for personal, professional, and
        informational purposes. You agree not to misuse the website, attempt to
        disrupt its operation, interfere with its security, or use it for
        unlawful activity.
      </p>

      <h2>Content and Ownership</h2>
      <p>
        Unless otherwise stated, the text, design, code, and other content on
        this website are owned by Riandoza or used with permission. You may link
        to this website and reference its public content, but you may not copy,
        republish, or present substantial portions as your own without
        permission.
      </p>

      <h2>Portfolio and Project Information</h2>
      <p>
        Project descriptions, skills, and availability information are provided
        for general informational purposes and may change over time. Nothing on
        this website guarantees a specific service, result, delivery timeline,
        or engagement.
      </p>

      <h2>External Links</h2>
      <p>
        This website links to third-party websites and profiles. I do not
        control those websites and am not responsible for their content,
        availability, privacy practices, or terms.
      </p>

      <h2>No Warranty</h2>
      <p>
        This website is provided as is and as available. I make no warranties
        that the site will be uninterrupted, error-free, secure, or suitable for
        a particular purpose.
      </p>

      <h2>Limitation of Liability</h2>
      <p>
        To the fullest extent permitted by law, I am not liable for damages
        arising from your use of, or inability to use, this website or linked
        third-party websites.
      </p>

      <h2>Contact</h2>
      <p>
        For questions about these terms, contact
        <a href="mailto:riandoza@gmail.com">riandoza@gmail.com</a>.
      </p>
    </article>
  </main>
  <Footer />
</Layout>
